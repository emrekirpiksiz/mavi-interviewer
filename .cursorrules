## DOSYA YAPISI KURALLARI

### Monorepo Yapisi

```
ai-interview/
├── apps/
│   ├── api/              # Express.js backend
│   │   └── src/
│   │       ├── routes/       # REST endpoints
│   │       ├── services/     # Business logic
│   │       ├── websocket/    # WS server & handlers
│   │       ├── db/           # DB connection & queries
│   │       ├── middleware/    # Express middleware
│   │       └── config/       # Environment config
│   └── web/              # Next.js frontend
│       └── src/
│           ├── app/          # App Router pages
│           ├── components/   # UI components
│           ├── hooks/        # Custom React hooks
│           ├── stores/       # Zustand stores
│           └── lib/          # Utilities
├── packages/
│   └── shared/           # Ortak types, constants
└── docs/                 # Dokumantasyon
    ├── plans/                # Mimari plan dokumanlari
    ├── features/             # Gelecek ozellik planlari
    ├── guides/               # Entegrasyon kilavuzlari
    └── samples/              # Ornek data
```

### Naming Conventions

```typescript
// Files
sessionService.ts     // camelCase
useWebSocket.ts       // hooks: use prefix
interviewStore.ts     // stores: store suffix

// Components
TranscriptPanel.tsx   // PascalCase
ControlBar.tsx

// Types
interface SessionData { }  // PascalCase
type InterviewState = ... // PascalCase

// Constants
const MAX_DURATION_MINUTES = 30;  // UPPER_SNAKE_CASE
const phases = ['introduction', ...];  // camelCase for arrays

// Functions
async function createSession() { }  // camelCase
function handleMessage() { }
```

---

## TEKNIK STANDARTLAR

### Backend (Express.js)

```typescript
// Route pattern
router.post('/sessions', validate(schema), controller.create);

// Service pattern
class SessionService {
  async create(data: CreateSessionInput): Promise<Session> { }
}

// Error handling
try {
  // logic
} catch (error) {
  console.error('[ServiceName] Error:', error);
  throw error;
}
```

### Frontend (Next.js)

```typescript
// Page component
export default function InterviewPage({ params }: { params: { sessionId: string } }) {
  const { session, pageState } = useInterviewStore();
  
  if (pageState === 'loading') return <LoadingScreen />;
  // ...
}

// Hook pattern
export function useWebSocket() {
  const [isConnected, setIsConnected] = useState(false);
  // ...
  return { connect, disconnect, send, isConnected };
}
```

### Database

```sql
-- Migration naming: 001_description.sql, 002_description.sql

-- Always use UUID for IDs
id UUID PRIMARY KEY DEFAULT gen_random_uuid()

-- Always include timestamps
created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW()

-- Soft delete
deleted_at TIMESTAMP WITH TIME ZONE
```

### WebSocket Events

```typescript
// Client → Server
{ event: 'interview:start', data: {} }
{ event: 'candidate:speaking:end', data: {} }

// Server → Client
{ event: 'connection:ready', data: { session: {...} } }
{ event: 'ai:speaking:start', data: { text: '...' } }
```

---

## UI STANDARTLARI

### Dark Mode Only

```css
/* globals.css temel renk paleti */
--bg-primary: #0a0a0f;
--bg-secondary: #12121a;
--text-primary: #ffffff;
--text-secondary: #a0a0b0;
--accent-primary: #3b82f6;
```

### Component Patterns

```tsx
// shadcn/ui kullan
import { Button } from '@/components/ui/button';

// Conditional className
<div className={cn(
  'base-classes',
  isActive && 'active-classes'
)}>

// Loading states
if (isLoading) return <Spinner />;
```

