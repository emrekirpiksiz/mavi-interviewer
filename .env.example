# ============================================
# AI INTERVIEW - ENVIRONMENT VARIABLES
# ============================================

# Database (NeonDB veya On-prem PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/interview_db

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ATS Integration
ATS_CALLBACK_URL=https://ats.example.com/api/interviews/callback
ATS_API_KEY=your-ats-api-key

# AI Services
ANTHROPIC_API_KEY=your-anthropic-key           # Claude API
OPENAI_API_KEY=your-openai-key                 # Whisper STT
ELEVENLABS_API_KEY=your-elevenlabs-key         # TTS
ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku       # Optional (default: Lily)
SIMLI_API_KEY=your-simli-key                   # Avatar (optional)

# Frontend (Public - exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
NEXT_PUBLIC_SIMLI_API_KEY=your-simli-key       # Avatar (optional)
